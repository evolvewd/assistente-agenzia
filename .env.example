# Anthropic API Key (obbligatoria per il backend).
# In locale: copia questo file in .env.local e inserisci la chiave.
# Su Vercel: aggiungi la variabile in Project Settings > Environment Variables (o Secrets).
ANTHROPIC_API_KEY=sk-ant-api03-...

# Password per proteggere l'accesso al cruscotto (opzionale).
# Se impostata, viene richiesta la login prima di vedere dati e usare le API.
# Su Vercel: aggiungila come Secret (Project Settings > Environment Variables > Add > Secret).
# In locale: in .env.local; se assente, l'app è accessibile senza password.
PROTECTION_PASSWORD=
